{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Elementium",
  "version": "0.1.0",
  "identifier": "io.github.elementium",
  "build": {
    "frontendDist": "../element-web-dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd .. && bash scripts/prepare-dev.sh",
    "beforeBuildCommand": "cd .. && bash scripts/prepare-build.sh"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: http: https: mxc:; connect-src 'self' http: https: ws: wss:; font-src 'self' data:; media-src 'self' blob:; frame-src 'self' blob: http: https:; worker-src 'self' blob:",
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1"
        ]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
